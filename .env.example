DISCORD_TOKEN=your_discord_bot_token_here

# Optional first-run default. You can set this later with /setchannel.
DISCORD_CHANNEL_ID=your_discord_channel_id_here

# Optional. Register slash commands instantly in one server.
# Without this, Discord global slash commands can take a while to appear.
DISCORD_GUILD_ID=your_discord_server_id_here

# Optional. Bot checks every 60 seconds by default.
CHECK_INTERVAL_SECONDS=60

# Optional. Only use if TikTok starts blocking anonymous LIVE checks.
TIKTOK_SESSION_ID=
TIKTOK_TT_TARGET_IDC=
